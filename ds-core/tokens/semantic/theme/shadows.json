{
  "shadow": {
    "button": {
      "$type": "boxShadow",
      "$value": {
        "x": "{dimension.0}",
        "y": "{dimension.100}",
        "blur": "{dimension.500}",
        "spread": "{dimension.0}",
        "color": "rgba({palette.base.black}, 0.12)",
        "type": "dropShadow"
      }
    },
    "fallback": {
      "button": {
        "$type": "boxShadow",
        "$value": {
          "x": "0",
          "y": "1",
          "blur": "3",
          "spread": "0",
          "color": "rgba({palette.base.black}, 0.1)",
          "type": "dropShadow"
        }
      }
    }
  }
}